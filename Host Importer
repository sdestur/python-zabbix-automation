import pandas as pd
from pyzabbix import ZabbixAPI
import logging

# --- Log Yönetimi ---
# İşlemlerin takibi için çıktı formatını ayarlıyoruz. 
# Hangi cihazda hata olduğunu buradan izleyebilirsiniz.
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')
logger = logging.getLogger(__name__)

# --- Zabbix Erişim Bilgileri ---
# URL: Zabbix arayüzüne girdiğiniz adresin sonuna '/api_jsonrpc.php' ekleyerek yazın.
# Token: Profil ayarlarınızdan (User Settings -> API Tokens) oluşturduğunuz anahtarı buraya girin.
ZABBIX_SERVER_URL = "http://ZABBIX_IP_ADRESINIZ/api_jsonrpc.php"
ZABBIX_API_TOKEN = "BURAYA_API_TOKEN_GELECEK"

# --- Dosya ve Veri Ayarları ---
CSV_FILE_PATH = "envanter_listesi.csv"
CSV_DELIMITER = ";"  # Excel'den CSV'ye aktarırken genellikle noktalı virgül kullanılır.

# --- SNMP Yapılandırması ---
# Bu ayarlar Zabbix'te Host eklerken "Interfaces" sekmesindeki SNMP alanına karşılık gelir.
# Versiyon 1, 2c veya 3 tercihinize göre aşağıdaki sözlüğü güncelleyebilirsiniz.
SNMP_CONFIG = {
    "version": 3,            # SNMP Versiyonu (1, 2 veya 3)
    "bulk": 1,               # GetBulk isteklerini etkinleştir (Önerilen: 1)
    "securityname": "v3_kullanici", # SNMPv3 Kullanıcı Adı
    "securitylevel": 2,      # 0: noAuthNoPriv, 1: authNoPriv, 2: authPriv (En güvenli)
    "authprotocol": 0,       # 0: MD5, 1: SHA1, 2: SHA224...
    "authpassphrase": "KIMLIK_DOGRULAMA_SIFRESI", 
    "privprotocol": 0,       # 0: DES, 1: AES128...
    "privpassphrase": "SIFRELEME_ANAHTARI",
    "contextname": ""
}

def get_zabbix_connection():
    """Zabbix API ile güvenli bağlantı kurar."""
    try:
        zapi = ZabbixAPI(ZABBIX_SERVER_URL, timeout=15)
        zapi.login(api_token=ZABBIX_API_TOKEN)
        logger.info(f"Zabbix Sunucusuna Bağlanıldı: {ZABBIX_SERVER_URL}")
        return zapi
    except Exception as e:
        logger.error(f"Bağlantı sırasında bir hata oluştu: {e}")
        raise

def sanitize_name(text):
    """
    Zabbix host adlarında Türkçe karakter veya boşluk kabul etmez. 
    Bu fonksiyon isimleri Zabbix'in seveceği formata getirir.
    """
    karakter_haritasi = {
        'ş':'s','Ş':'S','ı':'i','İ':'I','ğ':'g','Ğ':'G',
        'ü':'u','Ü':'U','ö':'o','Ö':'O','ç':'c','Ç':'C'
    }
    for tr, eng in karakter_haritasi.items():
        text = text.replace(tr, eng)
    return text.replace(" ", "-").replace(".", "").strip()

def run_import():
    """Ana içe aktarma süreci."""
    zapi = get_zabbix_connection()
    
    # CSV dosyasını bellek üzerine alıyoruz
    try:
        df = pd.read_csv(CSV_FILE_PATH, delimiter=CSV_DELIMITER, encoding="utf-8-sig")
    except FileNotFoundError:
        logger.error(f"Hata: '{CSV_FILE_PATH}' dosyası bulunamadı!")
        return

    # ÖNEMLİ: Aşağıdaki ID'leri kendi Zabbix sisteminizden almalısınız.
    # Host Group ID ve Template ID değerlerini Zabbix URL'sinden görebilirsiniz.
    HEDEF_GRUP_ID = "15"     # Örn: Network Cihazları Grubu
    SABLON_ID = "10106"      # Örn: 'Cisco IOS by SNMP' şablonu

    for index, row in df.iterrows():
        try:
            # CSV'deki sütun başlıklarını buraya tanımlayın
            cihaz_adi = str(row['Caption'])
            ip_adresi = str(row['IP_Address'])
            
            temiz_isim = sanitize_name(cihaz_adi)
            
            # Dinamik Etiketler (Tags): Zabbix arayüzündeki 'Tags' sekmesi.
            # Raporlama ve Dashboard oluştururken hayat kurtarır.
            etiketler = [
                {"tag": "Sehir", "value": str(row.get('İl', 'Belirtilmedi'))},
                {"tag": "Departman", "value": str(row.get('Departman', 'BT'))},
                {"tag": "Otomasyon", "value": "Python-API"}
            ]

            # Sistemde bu isimle bir cihaz var mı kontrol et?
            mevcut_host = zapi.host.get(filter={"host": temiz_isim})

            if mevcut_host:
                # Cihaz varsa sadece etiketleri ve şablonu güncelle (Update)
                zapi.host.update(
                    hostid=mevcut_host[0]['hostid'], 
                    tags=etiketler
                )
                logger.info(f"MEVCUT GÜNCELLENDİ: {temiz_isim}")
            else:
                # Cihaz yoksa sıfırdan oluştur (Create)
                # 'interfaces' kısmı cihazın hangi IP ve SNMP ayarıyla izleneceğini belirler.
                zapi.host.create(
                    host=temiz_isim,
                    name=cihaz_adi, # Arayüzde görünecek 'Visible Name'
                    interfaces=[{
                        "type": 2,      # 2 numaralı tip SNMP arayüzünü temsil eder
                        "main": 1, 
                        "useip": 1, 
                        "ip": ip_adresi,
                        "port": "161", 
                        "details": SNMP_CONFIG # Yukarıdaki SNMPv3 ayarlarını basar
                    }],
                    groups=[{"groupid": HEDEF_GRUP_ID}],
                    templates=[{"templateid": SABLON_ID}],
                    tags=etiketler,
                    inventory_mode=1 # Envanter verisini otomatik doldurmayı açar
                )
                logger.info(f"YENİ OLUŞTURULDU: {temiz_isim} ({ip_adresi})")

        except Exception as e:
            logger.error(f"Satır {index} işlenirken hata oluştu ({cihaz_adi}): {e}")

if __name__ == "__main__":
    logger.info("Zabbix içe aktarma işlemi başlıyor...")
    run_import()
    logger.info("İşlem tamamlandı.")
